@model StatementEditViewModel

@{
    var totalDebit = Model.TotalDebit;
    var totalCredit = Model.TotalCredit;
}

<form method="post" asp-action="SubmitEdits">
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.BankName)
    @Html.HiddenFor(m => m.AccountNumber)
    @Html.HiddenFor(m => m.AccountHolderName)
    @Html.HiddenFor(m => m.AccountType)
    @Html.HiddenFor(m => m.Currency)
    @Html.HiddenFor(m => m.CustomerName)
    @Html.HiddenFor(m => m.CustomerAccountNo)
    @Html.HiddenFor(m => m.CustomerAccountType)
    @Html.HiddenFor(m => m.CustomerCurrency)
    @Html.HiddenFor(m => m.CustomerBranch)
    @Html.HiddenFor(m => m.CustomerCIF)

    <div class="card shadow-sm mb-4">
        @* ── Row 1: Bank Name (full width) ── *@
        <div class="card-header text-center bg-success text-white py-3">
            <h4 class="mb-0"><i class="bi bi-bank"></i> @Model.BankName</h4>
        </div>

        @* ── Row 2: Two-column info section ── *@
        <div class="card-body bg-light">
            <div class="row">
                @* ── Left column ── *@
                <div class="col-md-6">
                    <div class="mb-2 row">
                        <label class="col-sm-5 col-form-label col-form-label-sm fw-semibold text-muted">Account Number</label>
                        <div class="col-sm-7">
                            <span class="form-control-plaintext form-control-sm py-1">
                                @Model.CustomerAccountNo
                            </span>
                        </div>
                    </div>
                    <div class="mb-2 row">
                        <label class="col-sm-5 col-form-label col-form-label-sm fw-semibold text-muted">Account Name</label>
                        <div class="col-sm-7">
                            <span class="form-control-plaintext form-control-sm py-1">
                                @Model.CustomerName
                            </span>
                        </div>
                    </div>
                    <div class="mb-2 row">
                        <label class="col-sm-5 col-form-label col-form-label-sm fw-semibold text-muted">Statement From</label>
                        <div class="col-sm-7">
                            <input type="text" class="summary-input" asp-for="FromDate"
                                   placeholder="dd/MM/yyyy" />
                        </div>
                    </div>
                    <div class="mb-2 row">
                        <label class="col-sm-5 col-form-label col-form-label-sm fw-semibold text-muted">Opening Balance</label>
                        <div class="col-sm-7">
                            <input type="text" class="summary-input text-end fw-medium text-primary"
                                   asp-for="OpeningBalance" placeholder="0.00" />
                        </div>
                    </div>
                </div>

                @* ── Right column ── *@
                <div class="col-md-6">
                    <div class="mb-2 row">
                        <label class="col-sm-5 col-form-label col-form-label-sm fw-semibold text-muted">Account Type</label>
                        <div class="col-sm-7">
                            <span class="form-control-plaintext form-control-sm py-1">
                                @Model.CustomerAccountType
                            </span>
                        </div>
                    </div>
                    <div class="mb-2 row">
                        <label class="col-sm-5 col-form-label col-form-label-sm fw-semibold text-muted">Currency</label>
                        <div class="col-sm-7">
                            <span class="form-control-plaintext form-control-sm py-1">
                                @Model.CustomerCurrency
                            </span>
                        </div>
                    </div>
                    <div class="mb-2 row">
                        <label class="col-sm-5 col-form-label col-form-label-sm fw-semibold text-muted">Statement To</label>
                        <div class="col-sm-7">
                            <input type="text" class="summary-input" asp-for="ToDate"
                                   placeholder="dd/MM/yyyy" />
                        </div>
                    </div>
                    <div class="mb-2 row">
                        <label class="col-sm-5 col-form-label col-form-label-sm fw-semibold text-muted">Closing Balance</label>
                        <div class="col-sm-7">
                            <input type="text" class="summary-input text-end fw-medium text-success"
                                   asp-for="ClosingBalance" placeholder="0.00" />
                        </div>
                    </div>
                </div>
            </div>

            @* ── Extra customer fields (Branch, CIF) if available ── *@
            @if (!string.IsNullOrEmpty(Model.CustomerBranch) || !string.IsNullOrEmpty(Model.CustomerCIF))
            {
                <hr class="my-2" />
                <div class="row text-muted small">
                    <div class="col">
                        @if (!string.IsNullOrEmpty(Model.CustomerBranch))
                        {
                            <span class="me-3"><strong>Branch:</strong> @Model.CustomerBranch</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.CustomerCIF))
                        {
                            <span><strong>CIF:</strong> @Model.CustomerCIF</span>
                        }
                    </div>
                </div>
            }
        </div>

        @* ── Transactions table ── *@
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0" id="editableTable">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3" style="width:120px">Date</th>
                            <th>Description</th>
                            <th style="width:160px">Ref / Cheque</th>
                            <th class="text-end" style="width:140px">Withdraw (Dr)</th>
                            <th class="text-end" style="width:140px">Deposit (Cr)</th>
                            <th class="text-end pe-3" style="width:140px">Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Transactions.Count; i++)
                        {
                            var txn = Model.Transactions[i];
                            <tr>
                                <td class="ps-3">
                                    @Html.HiddenFor(m => m.Transactions[i].RowIndex)
                                    <input type="text" class="td-input"
                                           asp-for="Transactions[i].Date"
                                           value="@txn.Date" />
                                </td>
                                <td>
                                    <input type="text" class="td-input"
                                           asp-for="Transactions[i].Description"
                                           value="@txn.Description" />
                                </td>
                                <td>
                                    <input type="text" class="td-input text-start"
                                           asp-for="Transactions[i].Reference"
                                           value="@txn.Reference" />
                                </td>
                                <td class="text-end">
                                    <input type="text" class="td-input text-end fw-medium text-danger"
                                           asp-for="Transactions[i].Debit"
                                           value="@txn.Debit?.ToString("N2")" />
                                </td>
                                <td class="text-end">
                                    <input type="text" class="td-input text-end fw-medium text-success"
                                           asp-for="Transactions[i].Credit"
                                           value="@txn.Credit?.ToString("N2")" />
                                </td>
                                <td class="text-end pe-3">
                                    <input type="text" class="td-input text-end fw-medium"
                                           asp-for="Transactions[i].Balance"
                                           value="@txn.Balance?.ToString("N2")" />
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-dark">
                        <tr>
                            <td class="ps-3" colspan="2">
                                <strong>Total</strong>
                                <span class="badge bg-info ms-2">@Model.Transactions.Count transactions</span>
                            </td>
                            <td></td>
                            <td class="text-end fw-bold">@totalDebit.ToString("N2")</td>
                            <td class="text-end fw-bold">@totalCredit.ToString("N2")</td>
                            <td class="text-end pe-3 fw-bold">@Model.ClosingBalance?.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">
                <i class="bi bi-pencil-square"></i> Click any cell or summary field to edit.
                <kbd>Enter</kbd> or click away to save.
            </small>
            <div>
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg"></i> Submit Transactions
                </button>
                <a asp-action="Upload" class="btn btn-outline-secondary ms-2">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
            </div>
        </div>
    </div>
</form>

@* ── Summary snapshot cards ── *@
@if (Model.Transactions.Count > 0)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-primary h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="card-title text-muted small mb-1">Opening Balance</h6>
                    <h4 class="text-primary mb-0">@Model.OpeningBalance?.ToString("N2")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="card-title text-muted small mb-1">Total Deposit</h6>
                    <h4 class="text-success mb-0">@totalCredit.ToString("N2")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="card-title text-muted small mb-1">Total Withdraw</h6>
                    <h4 class="text-danger mb-0">@totalDebit.ToString("N2")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-dark h-100">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="card-title text-muted small mb-1">Closing Balance</h6>
                    <h4 class="mb-0">@Model.ClosingBalance?.ToString("N2")</h4>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* ── Summary inputs (editable fields in header) ── */
    .summary-input {
        border: none;
        background: rgba(255, 255, 255, 0.7);
        padding: 4px 8px;
        width: 100%;
        box-sizing: border-box;
        font: inherit;
        color: inherit;
        border-radius: 3px;
        outline: none;
        transition: background 0.15s, border-color 0.15s;
        line-height: 1.4;
    }
    .summary-input:hover {
        background: rgba(255, 255, 255, 0.9);
    }
    .summary-input:focus {
        background: #fff;
        border: 1px solid #86b7fe;
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15);
        cursor: text;
    }

    /* ── Table cell inputs (invisible until focused) ── */
    #editableTable input[type="text"].td-input {
        border: none;
        background: transparent;
        padding: 6px 4px;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
        font: inherit;
        color: inherit;
        cursor: default;
        outline: none;
        transition: background 0.15s, border-color 0.15s;
        line-height: 1.4;
    }
    #editableTable td:hover input[type="text"].td-input {
        background: rgba(255, 255, 255, 0.4);
        border-radius: 3px;
    }
    #editableTable input[type="text"].td-input:focus {
        background: #fff;
        border: 1px solid #86b7fe;
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15);
        border-radius: 3px;
        cursor: text;
        box-sizing: border-box;
    }
    #editableTable td {
        padding: 2px 4px !important;
        vertical-align: middle;
    }
    #editableTable td:first-child { padding-left: 12px !important; }
    #editableTable td:last-child { padding-right: 12px !important; }
</style>

@section Scripts {
    <script>
        (function() {
            const table = document.getElementById('editableTable');
            if (!table) return;

            table.querySelectorAll('td').forEach(cell => {
                cell.addEventListener('click', function(e) {
                    if (e.target.tagName === 'INPUT') return;
                    const input = this.querySelector('input[type="text"]');
                    if (input) { input.focus(); input.select(); }
                });
            });

            table.querySelectorAll('input[type="text"]').forEach(input => {
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        this.blur();
                        const inputs = Array.from(
                            table.querySelectorAll('input[type="text"]')
                        );
                        const idx = inputs.indexOf(this);
                        if (idx >= 0 && idx < inputs.length - 1) {
                            inputs[idx + 1].focus();
                            inputs[idx + 1].select();
                        }
                    }
                });
            });
        })();
    </script>
}
