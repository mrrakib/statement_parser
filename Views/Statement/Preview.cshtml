@model StatementEditViewModel
@{
    ViewData["Title"] = "Statement Preview";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Upload">Upload</a></li>
            <li class="breadcrumb-item active">Preview &amp; Edit</li>
        </ol>
    </nav>

    @if (TempData["Success"] is not null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            @if (TempData["Confidence"] is not null)
            {
                <span class="badge bg-info ms-2">Confidence: @TempData["Confidence"]</span>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] is not null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <partial name="_TransactionTable" model="Model" />

    <div class="mt-3 d-flex gap-2">
        <a asp-action="Upload" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Upload Another
        </a>
    </div>
</div>
