@model CustomerInfo
@{
    ViewData["Title"] = "Solvency Certificate";
}

<div class="container mt-4 text-center py-5">
    <div class="display-1 text-warning mb-4">
        <i class="bi bi-tools"></i>
    </div>
    <h2>Solvency Certificate</h2>
    <p class="text-muted lead">
        This feature is under development and will be available soon.
    </p>
    <div class="card bg-light mx-auto mt-4" style="max-width:500px">
        <div class="card-body text-start small">
            <h6>Customer</h6>
            <div class="row mb-1"><div class="col-4 fw-medium">Account:</div><div class="col-8">@Model.AccountNo</div></div>
            <div class="row mb-1"><div class="col-4 fw-medium">Name:</div><div class="col-8">@Model.AccountName</div></div>
            <div class="row mb-1"><div class="col-4 fw-medium">Type:</div><div class="col-8">@Model.AccountType</div></div>
            <div class="row mb-1"><div class="col-4 fw-medium">CIF:</div><div class="col-8">@Model.CIF</div></div>
        </div>
    </div>
    <div class="mt-4">
        <a asp-action="SelectService" class="btn btn-primary">
            <i class="bi bi-arrow-left"></i> Back to Services
        </a>
    </div>
</div>
